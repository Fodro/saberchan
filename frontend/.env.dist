# Copy to frontend/.env for local `make ci` / `npm run dev`
#   cp frontend/.env.dist frontend/.env
#
# Docker builds inject these via Dockerfile ARG/ENV instead.

MAIN_BACKEND_URL=http://localhost:8888
# Must match backend ADMIN_API_TOKEN (BFF sends X-Admin-Token).
ADMIN_API_TOKEN=local-admin-api-token-change-me
AUTH_HOST=http://localhost:3000
AUTH_SECRET=local-auth-secret-change-me
OIDC_CLIENT_ID=saberchan
OIDC_CLIENT_SECRET=change-me-after-keycloak-setup
OIDC_REALM=http://localhost:9090/realms/saberchan
OIDC_REALM_INTERNAL=http://localhost:9090/realms/saberchan
OIDC_REDIRECT_URI=http://localhost:3000/admin/auth/signIn
OIDC_LOGOUT_REDIRECT_URI=http://localhost:3000/admin/auth/signOut
